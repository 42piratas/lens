#!/usr/bin/env bash
# Pre-commit — enforce worktree-mandatory + no-direct-integration-branch commits.
#
# Per principles-base.md §14 (Worktree path; main-checkout-read-only;
# Integration branch marker) and Invariant 1 of skill-git-multi-agent.md.
#
# Applies whenever .repo-class is set (canon | meta | app). No-op if missing.
# Reads .integration-branch (default: main) to know which branch to protect.

set -euo pipefail

repo_root="$(git rev-parse --show-toplevel)"
class_file="${repo_root}/.repo-class"
[ -f "$class_file" ] || exit 0
class="$(tr -d '[:space:]' < "$class_file")"

case "$class" in
  canon|meta|app) ;;
  *) exit 0 ;;
esac

# Integration branch defaults to main; project overrides via .integration-branch.
integ_branch="main"
if [ -f "${repo_root}/.integration-branch" ]; then
  integ_branch="$(tr -d '[:space:]' < "${repo_root}/.integration-branch")"
fi

# 1. Worktree-identity check: commit must originate from an added worktree,
#    not the main checkout. Detection: `git rev-parse --git-dir` returns
#    `.git/worktrees/<name>` inside an added worktree, but `.git` (or an
#    absolute path ending in `/.git`) inside the main checkout.
git_dir="$(git rev-parse --git-dir)"
case "$git_dir" in
  *.git/worktrees/*) ;;        # added worktree — OK
  *)
    echo "" >&2
    echo "✘ pre-commit blocked — commit must run in an added worktree, not the main checkout." >&2
    echo "  Single-repo / canon:  git worktree add .worktrees/{branch} -b {branch} origin/${integ_branch}" >&2
    echo "  Multi-repo project:   git worktree add ../worktrees/{repo}--{branch} -b {branch} origin/${integ_branch}" >&2
    echo "" >&2
    exit 1
    ;;
esac

# 2. Branch check: even from a worktree, never commit directly on the integration branch.
branch="$(git symbolic-ref --short HEAD 2>/dev/null || true)"
if [ "$branch" = "$integ_branch" ]; then
  echo "" >&2
  echo "✘ pre-commit blocked — repo-class=$class disallows commits directly on $integ_branch (integration branch)." >&2
  echo "  Use a feature branch (e.g. chore/<agent>-YYYYMMDD-<slug>) and FF-merge into $integ_branch when ready." >&2
  echo "" >&2
  exit 1
fi
