# LENS — example environment variables.
# Copy to `.env.local` (never commit) and fill the values you need.

# ─────────────────────────────────────────────────────────────────────────
# Supabase (b02-15 — multi-user auth + per-user state)
#
# Provision a Supabase project, then run `supabase/migrations/0001_init_auth.sql`
# (Studio → SQL Editor, or via `supabase db push` if you use the CLI).
# Service-role key is server-only — never bundled into client output.
# JWT secret signs the per-request access JWT used by RLS policies.
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_JWT_SECRET=

# ─────────────────────────────────────────────────────────────────────────
# Auth.js / next-auth (b02-15)
#
# AUTH_SECRET — generate with `openssl rand -base64 32`. Used to sign session
#   cookies (JWT strategy) and CSRF tokens.
# AUTH_URL    — public origin of the app. Set to `http://localhost:3000`
#   in dev; the deployed value is the production URL.
# Google OAuth web client — register at https://console.cloud.google.com/.
#   Add the redirect URI `http://localhost:3000/api/auth/callback/google`
#   for dev (and the production equivalent for prod). The "Desktop"-type
#   client used by the legacy `scripts/google-oauth.mjs` flow is a separate
#   client and cannot be reused — Auth.js requires the "Web application"
#   client type with redirect URIs registered.
# ─────────────────────────────────────────────────────────────────────────
AUTH_SECRET=
AUTH_URL=http://localhost:3000

# ─────────────────────────────────────────────────────────────────────────
# Google OAuth client (web type) — used by next-auth sign-in.
# Add redirect URIs `http://localhost:3000/api/auth/callback/google` and
# `https://<your-deployment>/api/auth/callback/google` to the client.
# Per-user refresh tokens live in `public.oauth_tokens` (vault-encrypted);
# the b02-pre-15 single-user `GOOGLE_CALENDAR_REFRESH_TOKEN` env var is
# removed in b02-15.
# ─────────────────────────────────────────────────────────────────────────
GOOGLE_OAUTH_CLIENT_ID=
GOOGLE_OAUTH_CLIENT_SECRET=

# ─────────────────────────────────────────────────────────────────────────
# Trello (public app key only — per-user tokens live in oauth_tokens)
#
# Generate at <https://trello.com/power-ups/admin>; allowed origins must
# include `http://localhost:3000` and `https://<your-deployment>`. Per-user
# tokens are obtained via the fragment-token flow at /settings (b02-15);
# the b02-pre-15 single-user `TRELLO_API_TOKEN` env var is removed.
# ─────────────────────────────────────────────────────────────────────────
TRELLO_API_KEY=

# ─────────────────────────────────────────────────────────────────────────
# Trakt (single-user API key — public lists only in v1)
# ─────────────────────────────────────────────────────────────────────────
TRAKT_CLIENT_ID=

# ─────────────────────────────────────────────────────────────────────────
# GitHub (GitHub App — read-only, per-repo; per-user tokens live in
# oauth_tokens). b02-13.
#
# Register a GitHub App at <https://github.com/settings/apps/new> with
# READ-ONLY permissions (Pull requests: Read, Issues: Read, Metadata: Read,
# Notifications: Read; no write). Enable "Request user authorization (OAuth)
# during installation" and DISABLE "Expire user authorization tokens".
# Callback URL: https://<your-deployment>/api/auth/github/callback
# (+ http://localhost:3000/api/auth/github/callback for dev).
# Users install + authorize from /settings → Connections → GitHub; they pick
# which repos to expose. See connectors/github/README.md.
# ─────────────────────────────────────────────────────────────────────────
GITHUB_APP_CLIENT_ID=
GITHUB_APP_CLIENT_SECRET=
GITHUB_APP_SLUG=

# ─────────────────────────────────────────────────────────────────────────
# Keep — service account + domain-wide delegation (b02-12).
#
# The Google Keep REST API is enterprise-only; it doesn't support standard
# user-OAuth scope grants. The only documented path is a Workspace admin
# granting a service account permission to impersonate users via DWD.
#
# Setup (one-time):
#   1. Create a service account in the GCP project that owns LENS.
#   2. In Workspace admin (admin.google.com) → Security → Access and data
#      control → API controls → Domain-wide delegation, register the SA's
#      client ID with scope https://www.googleapis.com/auth/keep.readonly.
#   3. Paste the SA's full JSON key into GOOGLE_KEEP_SA_KEY_JSON below
#      (single line — minify the JSON).
#   4. Set LENS_KEEP_WORKSPACE_DOMAIN to the Workspace primary domain the
#      DWD applies to (e.g. "42labs.io"). Only users whose
#      session.user.hd matches this get Keep auto-on.
# Both NEXT_PUBLIC_LENS_KEEP_WORKSPACE_DOMAIN and LENS_KEEP_WORKSPACE_DOMAIN
# must be set to the same value — the client-side picker reads the public
# variant; the server-side fetcher reads the private one.
# ─────────────────────────────────────────────────────────────────────────
GOOGLE_KEEP_SA_KEY_JSON=
LENS_KEEP_WORKSPACE_DOMAIN=
NEXT_PUBLIC_LENS_KEEP_WORKSPACE_DOMAIN=
# Debug affordances (optional)
# ─────────────────────────────────────────────────────────────────────────
NEXT_PUBLIC_LENS_DEBUG=
